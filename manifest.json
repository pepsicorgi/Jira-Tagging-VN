{
  "manifest_version": 3,
  "name": "Jira Tagging VN",
  "version": "1.3",
  "permissions": ["storage"],
  "description": "Testing Tagging Jira VN Extension",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://jira.secext.samsung.net/browse/*"],
      "css": ["src/styles/main.css"],
      "js": ["src/content/index.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/*.js", "src/utils/*.js"],
      "matches": ["https://jira.secext.samsung.net/*"]
    }
  ]
}